# ⚠️ SECURITY WARNING: This file documents required environment variables
# ⚠️ NEVER commit actual .env to git - it will be ignored by .gitignore
# Copy this file to .env.local and fill in your ACTUAL secure values

# === DATABASE (CRITICAL) ===
# Use strong, cryptographically random passwords for production
# Example format: postgresql://user:randomPassword@host:port/database
# Generate password: openssl rand -hex 32
DATABASE_URL="postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@localhost:5432/chms?sslmode=require"

# === JWT SECRETS (CRITICAL) ===
# Generate strong random secrets for production ONLY
# Command to generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER use placeholder values in production
JWT_SECRET="GENERATE_STRONG_RANDOM_STRING_NOT_THIS_PLACEHOLDER"
JWT_EXPIRATION="1h"
JWT_REFRESH_SECRET="GENERATE_ANOTHER_STRONG_RANDOM_STRING_NOT_THIS_PLACEHOLDER"
JWT_REFRESH_EXPIRATION="7d"

# === SERVER CONFIG ===
PORT=3001
NODE_ENV="development"

# Development
FRONTEND_URL="http://localhost:3000"

# Production with Dev Tunnels
# FRONTEND_URL="https://your-tunnel-id.devtunnels.ms/"
# NODE_ENV="production"

# === EXTERNAL APIs (Optional) ===
# FDA_API_KEY="your-api-key-if-needed"
# MAPBOX_ACCESS_TOKEN="your-token-if-needed"

